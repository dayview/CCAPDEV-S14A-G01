<!DOCTYPE html>
<html lang = "en">
  <head>
    <meta charset = "UTF-8">
    <title> Sign-Up </title>
    <link rel = "stylesheet" href = "/css/main.css">
    <link rel = "stylesheet" href = "/css/signup.css">
  </head>
  <body>
    <section class = "header">
      <img src = "/images/dlsu-logo-white.png" alt = "DLSU Logo" height = "30">
    </section>

    <form id = "signup">
      <div class = "signup_block">
        <h2 class = "signup"> SIGN-UP </h2>
        {{#if error}}
        <p class = "error-message"> {{error}} </p>
        {{/if}}
        <div class = "id">
          <label> ID Number * </label>
          <input type = "text" id = "id_number" value = "{{form.idnumber}}" required>
        </div>
        <div class = "username">
          <label> Username * </label>
          <input type = "text" id = "user" value = "{{form.username}}" required>
        </div>
        <div class = "password">
          <label> Password * </label>
          <input type = "password" id = "password" required>
        </div>
        <div class = "email">
          <label> Email * </label>
          <input type = "email" id = "email" value = "{{form.email}}" required>
        </div>
        <div class = "buttons">
          <button type = "submit" class = "submit-btn"> Sign-Up </button>
        </div>
        <a href = "/login" class = "login-link"> Already have an account? </a>
      </div>
    </form>
    <script src = "/js/signup.js"></script>
            
  </body>
</html>
