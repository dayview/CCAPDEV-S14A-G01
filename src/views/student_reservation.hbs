<link rel="stylesheet" href="/css/reservation_history.css">

<section class="history_page">
    <div class="history_container">
        <h1 class="page_title">My Reservation History</h1>

        <div class="user_info">
            <p><strong>Student ID:</strong> <span id="userIdDisplay"></span></p>
        </div>

        <div class="filter_section">
            <label for="filterStatus">Filter by:</label>
            <select id="filterStatus">
                <option value="all">All Reservations</option>
                <option value="upcoming">Upcoming</option>
                <option value="past">past</option>
            </select>
        </div>

        <div class="table_container">
            <table class="history_table">
                <thead>
                    <tr>
                        <th>Laboratory</th>
                        <th>Seat</th>
                        <th>Date</th>
                        <th>Time In</th>
                        <th>Time Out</th>
                        <th>Status</th>
                        <th>Anonymous</th>
                    </tr>
                </thead>
                <tbody id="history_body">
                    {{#each slots}}
                    <tr>
                        <td>{{this.lab.labName}}</td>
                        <td>{{this.seatNum}}</td>
                        <td>{{this.date}}</td>
                        <td>{{this.startTime}}</td>
                        <td>{{this.endTime}}</td>
                        <td>{{this.status}}</td>
                        <td>-</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>

        <div id="noReservations" class="no_reservations" style="display: none;">
            <p>You have no reservations yet.</p>
            <a href="reservation.html" class="btn">Make a Reservation</a>
        </div>
    </div>
</section>

<script src="../js/reservation_history.js"></script>