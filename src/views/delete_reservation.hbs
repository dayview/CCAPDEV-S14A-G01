<!DOCTYPE html>
<html lang = "en">
<head> 
  <meta charset = "UTF-8">
  <title> Delete Reservation </title>
  <link rel = "stylesheet" href = "/css/main.css">
  <link rel = "stylesheet" href = "/css/deletereservation.css">
</head>

<body> 
<section class = "header">
  <div class = "logo">
    <img src = "/images/dlsu-logo-white.png" alt = "DLSU Logo" height = "30">
  </div>

   <div class = "header-actions">
     <a href = "/user_profile" class = "btn"> User Profile </a>
   </div>
</section>

<section class = "delete-page">
  <h2> Your Reservations </h2>
  {{#if reservations.length}}
    <p id = "noreservation" style = "display:none;"> You currently have no reservations </p>

    <table id = "reservationtable">
      <thead>
        <tr>
          <th> Date </th>
          <th> Time </th>
          <th> Room </th>
          <th> Seat </th>
          <th> Anonymous </th>
          <th> Status </th>
          <th> Action </th>
        </tr>
      </thead>

      <tbody id = "resrevationbody">
        {{#each reservations}}
        <tr> 
          <td>{{this.date}}</td>
          <td>{{this.time}}</td>
          <td>{{this.room}}</td>
          <td>{{this.seat}}</td>
          <td>{{#if this.anonymous}}Yes{{else}}No{{/if}}</td>
          <td>{{this.status}}</td>
          <td> 
            <button class = "deletebtn" data-id = "{{this._id}}"> Delete </button>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  {{else}}
    <p id = "noreservation"> You currently have no reservations </p>
  {{/if}}

  <script src = "/js/deletereservation.js"></script>
</body>
</html>
