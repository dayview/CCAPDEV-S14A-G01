{{#> (layout "admin")}}

<section class="history_page">
    <div class="history_container">
        <h1 class="page_title">STUDENT RESERVATION HISTORY</h1>

        <div class="search_section">
            <label class="input_label">STUDENT USER ID</label>
            <div class="search_row">
                <input type="text" class="student_input" id="student_id_input" placeholder="Enter 8-digit Student ID"
                    maxlength="8">
                <button class="search_button" id="search_btn">SEARCH</button>
            </div>
        </div>

        <div class="student_info" id="student_info" style="display: none;">
            <p><strong>Student ID:</strong> <span id="displayStudentId"></span></p>
        </div>

        <div class="error_message" id="error_message" style="display: none;">
            <p>Error: Student ID not registered in the system.</p>
        </div>

        <div class="filter_section" id="filter_section" style="display: none;">
            <label for="filterStatus">Filter by:</label>
            <select id="filterStatus">
                <option value="all">All Reservations</option>
                <option value="upcoming">Upcoming</option>
                <option value="past">Past</option>
            </select>
        </div>

        <div class="table_container" id="table_container" style="display: none;">
            <table class="history_table">
                <thead>
                    <tr>
                        <th>Laboratory</th>
                        <th>Seat</th>
                        <th>Date</th>
                        <th>Time In</th>
                        <th>Time Out</th>
                        <th>Status</th>
                        <th>Anonymous</th>
                    </tr>
                </thead>
                <tbody id="history_body">
                </tbody>
            </table>
        </div>

        <div id="noReservations" class="no_reservations" style="display: none;">
            <p>This student has no reservations.</p>
        </div>
    </div>
</section>

<script src="../js/header_navigation.js"></script>
<script src="../js/admin_reservation_history.js"></script>