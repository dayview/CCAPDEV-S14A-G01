<link rel="stylesheet" href="/css/user_profile.css">

<section class = "header">
    <h1><b>DLSU</b> Lab Reservation</h1>
    <a href="/reservation" class = "btn"> Return to Home </a>
</section>

<section class="page">
    <div id="userInfo">
        <p><strong>Name: </strong> {{user.firstName}} {{user.lastName}}</p>
        <p><strong>Username: </strong> {{user.username}}</p>
        <p><strong>ID Number: </strong> {{user.idNum}}</p>
    </div>

    <a href="/auth/profile">User Information</a>
    <a href="/reservation/search">Search Reservation</a>
    <a href="/reservation/edit">Edit Reservation</a>
    <a href="/reservation/delete">Delete Reservation</a>
    
    <div class="profile-actions" style="margin-top: 20px;">
        <button id="logout_btn" type="button">Logout</button>
        
        <form action="/auth/delete-profile" method="POST" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete your account? This will cancel all your pending reservations and cannot be undone.');">
            <button type="submit" id="delete_profile_btn">Delete Profile</button>
        </form>
    </div>
</section>
<script src="/js/user_profile.js"></script>
<script src = "/js/user_profile.js"></script>
