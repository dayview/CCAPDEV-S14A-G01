<link rel="stylesheet" href="/css/user_profile.css">

<section class = "header">
    <h1><b>DLSU</b> Lab Reservation</h1>
    <a href="/reservation" class = "btn"> Return to Home </a>
</section>

<section class="page">
    <form id = "userInfo" action="/reservation/user_profile" method="POST" enctype = "multipart/form-data">
            {{#if error}}
                <p class = "form-error">{{error}}</p>
            {{/if}}

            <p><strong>Name: </strong>{{user.firstName}} {{user.lastName}}</p>
            <p><strong>ID Number: </strong>{{user.idNum}}</p>

             {{#if user.profilePicture}}
                <img src = "{{user.profilePicture}}" alt = "Profile Picture" class = "profile-pic-preview">
             {{/if}}

            <label for = "profilePicture"><strong>Profile Picture: </strong></label>
            <input type = "file" id = "profilePicture" name = "profilePicture" accept="image/*">

            <label for = "description"><strong>Description: </strong></label>
            <input type = "text" id = "description" name = "description" value = "{{user.description}}">

            <label for = "username"><strong>Username: </strong></label>
            <input type = "text" id = "username" name = "username" value ="{{user.username}}">

            <label for = "password"><strong>New Password: </strong></label>
            <input type = "password" id = "password" name = "password">

            <label for = "password"><strong>Confirm Password: </strong></label>
            <input type = "password" id = "confirmPassword" name = "confirmPassword">

            <button type = "submit">Save Changes</button>
    </form>


    <div class="search-container">
    <h3>View another User's Profile</h3>
    <form action="/auth/search" method="GET" class="search-form">
        <input type="text" name="q" placeholder="First Name and Last Name" class="search-input" required>
        <button type="submit" class="search-btn">Search</button>
    </form>
    </div>
    
    <a href="/reservation/reservation_history">My Reservation</a>
    <a href="/reservation/edit">Edit Reservation</a>
    <a href="/reservation/delete">Delete Reservation</a>
    <button id="logout_btn" type="button">Logout</button>
</section>
